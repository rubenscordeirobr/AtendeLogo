<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["_content/AtendeLogo.UI/css/ui.css"]" />
    <link rel="stylesheet" href="@Assets["_content/AtendeLogo.TenantPortal/css/tenant-portal.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["AtendeLogo.TenantPortal.BlazorServer.styles.css"]" />
    
    <ImportMap />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    
    <HeadOutlet @rendermode="PageRenderMode" />

</head>

<body>
    @*
    <script src="@Assets["_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js"]" type="text/javascript"></script> 
    *@
    <Routes @rendermode="PageRenderMode" />

    <script src="_framework/blazor.web.js"></script>

</body>

</html>

@code {

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;


    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

    
}
